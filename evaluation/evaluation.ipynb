   "source": [
    "# ============================================================\n",
    "# MODEL CONFIDENCE SET (MCS)\n",
    "# Hansen, Lunde & Nason (2011)\n",
    "# Metrics: QLIKE, Frobenius, Var MSE, Corr MSE – Full Sample\n",
    "# Builds on: cov_losses, component_losses, MODEL_ORDER, H\n",
    "# ============================================================\n",
    "\n",
    "from arch.bootstrap import MCS\n",
    "from IPython.display import display\n",
    "\n",
    "MCS_SIZE = 0.10\n",
    "\n",
    "MCS_METRICS = [\n",
    "    (\"QLIKE\",     cov_losses,       \"QLIKE\"),\n",
    "    (\"FROBENIUS\", cov_losses,       \"Frobenius\"),\n",
    "    (\"VAR_MSE\",   component_losses, \"Var MSE\"),\n",
    "    (\"CORR_MSE\",  component_losses, \"Corr MSE\"),\n",
    "]\n",
    "\n",
    "\n",
    "def run_mcs(loss_dict, metric, model_order, size=MCS_SIZE, seed=42):\n",
    "    losses_df = pd.DataFrame({\n",
    "        model: loss_dict[model][metric].dropna()\n",
    "        for model in model_order\n",
    "        if model in loss_dict\n",
    "    }).dropna()\n",
    "\n",
    "    mcs = MCS(losses_df, size=size, seed=seed)\n",
    "    mcs.compute()\n",
    "\n",
    "    pvals = mcs.pvalues.copy()\n",
    "    pvals.columns = [\"p_value\"]\n",
    "    pvals[\"in_MCS\"] = pvals[\"p_value\"] > size\n",
    "    pvals = pvals.reindex([m for m in model_order if m in pvals.index])\n",
    "    return pvals\n",
    "\n",
    "\n",
    "# --- Bygg samletabell ---\n",
    "mcs_combined = {}\n",
    "\n",
    "for metric, loss_dict, label in MCS_METRICS:\n",
    "    result = run_mcs(loss_dict, metric, MODEL_ORDER)\n",
    "\n",
    "    mcs_combined[f\"{label} p-val\"] = result[\"p_value\"].apply(lambda p: f\"{p:.3f}\")\n",
    "    mcs_combined[f\"{label} sig\"]   = result[\"p_value\"].apply(\n",
    "        lambda p: \"***\" if p < 0.01 else (\"**\" if p < 0.05 else (\"*\" if p < 0.10 else \"  \"))\n",
    "    )\n",
    "    mcs_combined[f\"{label} in MCS\"] = result[\"in_MCS\"].map({True: \"✓\", False: \"\"})\n",
    "\n",
    "mcs_table = pd.DataFrame(mcs_combined)\n",
    "mcs_table.index.name = \"Model\"\n",
    "mcs_table = mcs_table.reindex([m for m in MODEL_ORDER if m in mcs_table.index])\n",
    "\n",
    "col_order = []\n",
    "for _, _, label in MCS_METRICS:\n",
    "    col_order += [f\"{label} p-val\", f\"{label} sig\", f\"{label} in MCS\"]\n",
    "mcs_table = mcs_table[col_order]\n",
    "\n",
    "print(\"=\" * 70)\n",
    "print(f\"MODEL CONFIDENCE SET (MCS)  |  H = {H}  |  Significance level: {int(MCS_SIZE*100)}%\")\n",
    "print(\"✓ = model included in MCS (cannot be rejected as equally good)\")\n",
    "print(\"* p<0.10   ** p<0.05   *** p<0.01\")\n",
    "print(\"=\" * 70)\n",
    "display(mcs_table)"
   ]
  }
